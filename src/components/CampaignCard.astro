---
/* Kampanya kartı — ana sayfa grid'inde gösterilir.
   Gradient tema header + beyaz bilgi gövdesi (imeclinic.com/link/ dili).
   Bilgi sırası: durum → fiyat/kapora/doktor (karar verdiren veri) → tagline (destekleyici). */
import { useTranslations } from "@/i18n/utils";
import { getCampaignContent } from "@/data/campaigns";
import type { Campaign } from "@/data/types";
import type { Lang } from "@/i18n/ui";

interface Props {
  campaign: Campaign;
  lang: Lang;
}
const { campaign, lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const { content, isFallback } = getCampaignContent(campaign, lang);
// İçerik hiç yoksa (TR bile yoksa) kartı render etme
if (!content) return Astro.redirect("/");

const href = `${base}${lang}/kampanya/${campaign.slug}/`;
---

<article class="campaign-card" data-theme={campaign.theme}>
  <a href={href} class="card-link" aria-label={content.name}>
    <!-- Gradient header -->
    <div class="card-header">
      <span class="card-icon" aria-hidden="true">{campaign.icon}</span>
      <div class="card-heading">
        <h3 class="card-title">{content.name}</h3>
        <p class="card-specialty">{content.specialtyTag}</p>
        <p class="card-hospital">
          <svg
            class="hosp-icon"
            viewBox="0 0 24 24"
            width="12"
            height="12"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 2 3 7v2h18V7l-9-5zM5 11v9h4v-5h6v5h4v-9H5zm6-3h2v2h2v2h-2v2h-2v-2H9v-2h2V8z"
            ></path>
          </svg>
          {t("card.atBht")}
        </p>
      </div>
    </div>

    <!-- Gövde -->
    <div class="card-body">
      <div class="badges">
        <span class={`badge status-${campaign.status}`}>
          {t(`status.${campaign.status}`)}
        </span>
        {isFallback && <span class="badge soon-badge">{t("card.soon")}</span>}
      </div>

      <dl class="meta">
        <div class="meta-item price-item">
          <dt>{t("card.price")}</dt>
          <dd class="price">{content.price}</dd>
        </div>
        <div class="meta-item">
          <dt>{t("card.deadline")}</dt>
          <dd>{content.dates.deposit}</dd>
        </div>
        <div class="meta-item">
          <dt>{t("card.doctor")}</dt>
          <dd class="doctor">{campaign.doctor}</dd>
        </div>
      </dl>

      <p class="tagline">{content.tagline}</p>
    </div>

    <!-- CTA -->
    <div class="card-footer">
      <span class="view-btn">
        {t("card.view")}
        <span class="arrow" aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>

<style>
  .campaign-card {
    background: #fff;
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    height: 100%;
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }
  .campaign-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 50px -16px rgb(45 75 107 / 0.28);
  }
  .card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  /* Gradient header */
  .card-header {
    background: linear-gradient(135deg, var(--theme), var(--theme-dark));
    color: #fff;
    padding: var(--space-4) var(--space-5);
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .card-icon {
    font-size: 1.9rem;
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 0.85rem;
    flex-shrink: 0;
  }
  .card-title {
    font-size: var(--text-xl);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }
  .card-specialty {
    display: inline-block;
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    margin-top: 0.4rem;
  }
  /* Tüm işlemler BHT Clinic bünyesinde — güven sinyali */
  .card-hospital {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: var(--text-2xs);
    font-weight: 600;
    opacity: 0.92;
    margin-top: 0.5rem;
  }
  .hosp-icon {
    flex-shrink: 0;
  }

  /* Gövde */
  .card-body {
    padding: var(--space-4) var(--space-5) var(--space-2);
    flex: 1;
  }
  .badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: var(--space-3);
  }
  .badge {
    font-size: var(--text-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.22rem 0.55rem;
    border-radius: 999px;
  }
  .status-active {
    background: #dcfce7;
    color: #15803d;
  }
  .status-soon {
    background: #fef3c7;
    color: #b45309;
  }
  .status-paused {
    background: #e2e8f0;
    color: #64748b;
  }
  .soon-badge {
    background: #fef3c7;
    color: #b45309;
  }

  /* Meta — sabit 2 kolon, fiyat tam genişlik ankor */
  .meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: var(--space-4);
    row-gap: 0.65rem;
  }
  .price-item {
    grid-column: 1 / -1;
  }
  .meta-item {
    display: flex;
    flex-direction: column;
  }
  .meta-item dt {
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 0.1rem;
  }
  .meta-item dd {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-brand-navy);
    line-height: 1.15;
  }
  .meta-item .price {
    color: var(--theme-dark);
    font-size: var(--text-xl);
    font-weight: 800;
  }
  .meta-item .doctor {
    font-size: var(--text-xs);
  }

  /* Tagline — ikincil, destekleyici */
  .tagline {
    margin-top: var(--space-3);
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-brand-ink);
    opacity: 0.85;
  }

  /* CTA */
  .card-footer {
    padding: 0.85rem var(--space-5) var(--space-5);
  }
  .view-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    background: var(--theme);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 700;
    padding: 0.7rem 1rem;
    border-radius: 0.75rem;
    transition: background 0.15s;
  }
  .campaign-card:hover .view-btn {
    background: var(--theme-dark);
  }
  .arrow {
    transition: transform 0.18s;
  }
  .campaign-card:hover .arrow {
    transform: translateX(3px);
  }
</style>
