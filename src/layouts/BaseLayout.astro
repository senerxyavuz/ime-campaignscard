---
/* IME Clinic Satış Portalı — Temel sayfa düzeni (head, font, blob arka plan, header/footer) */
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import type { Lang } from "@/i18n/ui";

interface Props {
  lang: Lang;
  title: string;
  description?: string;
  /** Üst boşluğu azalt (ana sayfa için daha sıkı) */
  compact?: boolean;
}

const { lang, title, description, compact = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Ekip içi araç — arama motorlarına kapalı -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#2d4b6b" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <!-- Dekoratif blob zemin -->
    <div class="blob-bg" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>

    <Header lang={lang} />

    <main class:list={["main", { compact }]}>
      <slot />
    </main>

    <Footer lang={lang} />

    <style>
      .main {
        max-width: 1120px;
        margin: 0 auto;
        padding: 1rem 1rem 3.5rem;
      }
      /* Ana sayfa: üst boşluğu daha çok daralt */
      .main.compact {
        padding-top: 0.4rem;
      }
      @media (min-width: 768px) {
        .main {
          padding: 1.5rem 1.5rem 4rem;
        }
        .main.compact {
          padding-top: 0.6rem;
        }
      }
    </style>
  </body>
</html>
