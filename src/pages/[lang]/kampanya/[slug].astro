---
/* Kampanya detay (satış kartı) — paket, kozlar, kurallar, WhatsApp, SSS, fiyat listesi */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { campaigns, getCampaign, getCampaignContent } from "@/data/campaigns";
import { langOrder, type Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

export function getStaticPaths() {
  return langOrder.flatMap((lang) =>
    campaigns.map((c) => ({ params: { lang, slug: c.slug } })),
  );
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const base = import.meta.env.BASE_URL;
const t = useTranslations(lang);

const campaign = getCampaign(slug);
if (!campaign) return Astro.redirect(`${base}${lang}/`);

const { content, isFallback } = getCampaignContent(campaign, lang);
if (!content) return Astro.redirect(`${base}${lang}/`);

// SSS'yi iki sütuna böl
const half = Math.ceil(content.faq.length / 2);
const faqLeft = content.faq.slice(0, half);
const faqRight = content.faq.slice(half);
---

<BaseLayout
  lang={lang}
  title={`${content.name} — IME Clinic`}
  description={content.tagline}
>
  <div class="detail" data-theme={campaign.theme}>
    <!-- Geri linki -->
    <a href={`${base}${lang}/`} class="back-link">
      <span aria-hidden="true">←</span> {t("nav.back")}
    </a>

    <!-- HERO -->
    <header class="d-hero">
      <div class="d-hero-main">
        <span class="d-icon" aria-hidden="true">{campaign.icon}</span>
        <div>
          <h1 class="d-title">{content.name}</h1>
          <p class="d-specialty">{content.specialtyTag}</p>
          <p class="d-doctor">
            {campaign.doctor}
            {content.hospitalNote && <span> · {content.hospitalNote}</span>}
          </p>
        </div>
      </div>
      {
        campaign.accreditation && (
          <span class="d-accred">{campaign.accreditation}</span>
        )
      }
    </header>

    <!-- Çeviri fallback uyarısı -->
    {
      isFallback && (
        <div class="fallback-note">
          ⓘ {t("card.soon")} — {content.name} içeriği şu an Türkçe gösteriliyor.
        </div>
      )
    }

    <!-- TARİH PİLLERİ -->
    <div class="date-pills">
      <div class="date-pill">
        <span class="dp-label">{t("detail.date.ad")}</span>
        <span class="dp-value">{content.dates.ad}</span>
      </div>
      <div class="date-pill key">
        <span class="dp-label">{t("detail.date.deposit")}</span>
        <span class="dp-value">{content.dates.deposit}</span>
      </div>
      <div class="date-pill">
        <span class="dp-label">{t("detail.date.treatment")}</span>
        <span class="dp-value">{content.dates.treatment}</span>
      </div>
      <div class="date-pill">
        <span class="dp-label">{t("detail.date.stay")}</span>
        <span class="dp-value">{content.dates.stay}</span>
      </div>
    </div>

    <!-- ANA GRID -->
    <div class="d-grid">
      <!-- PAKET -->
      <section class="info-card">
        <div class="ic-head theme-head">{t("detail.package")}</div>
        <div class="price-hero">
          <span class="price-label">{t("card.price")}</span>
          <div class="price-big">{content.price}</div>
          <div class="price-note">{content.priceNote}</div>
        </div>
        <div class="ic-body">
          <ul class="check-list">
            {
              content.packageItems.map((item) => (
                <li>
                  <span class="ic-yes" aria-hidden="true">
                    ✓
                  </span>
                  <span set:html={item} />
                </li>
              ))
            }
          </ul>
          <div class="not-included">
            <span class="ni-label">{t("detail.notIncluded")}</span>
            <div class="ni-items">
              {
                content.notIncluded.map((item) => (
                  <span class="ni-item">
                    <span class="ni-x" aria-hidden="true">
                      ✗
                    </span>{" "}
                    {item}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <!-- SATIŞ KOZLARI -->
      <section class="info-card">
        <div class="ic-head green-head">{t("detail.advantages")}</div>
        <div class="ic-body">
          <ul class="koz-list">
            {
              content.advantages.map((adv) => (
                <li class="koz">
                  <span class="koz-star" aria-hidden="true">
                    ★
                  </span>
                  <span>
                    <strong>{adv.title}:</strong> {adv.body}
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- KRİTİK KURALLAR (tam genişlik) -->
      <section class="info-card full">
        <div class="ic-head amber-head">{t("detail.rules")}</div>
        <div class="ic-body">
          <ul class="rule-list">
            {
              content.rules.map((rule) => (
                <li class="rule">
                  <span class="rule-badge">{rule.badge}</span>
                  <span set:html={rule.text} />
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- SSS (full width) -->
      <section class="info-card full">
        <div class="ic-head theme-head">{t("detail.faq")}</div>
        <div class="faq-columns">
          <div class="faq-col">
            {
              faqLeft.map((item) => (
                <div class="faq-item">
                  <button class="faq-q" data-faq-toggle>
                    <span>{item.q}</span>
                    <span class="faq-arrow" aria-hidden="true">
                      ▾
                    </span>
                  </button>
                  <div class="faq-a" set:html={item.a} />
                </div>
              ))
            }
          </div>
          <div class="faq-col">
            {
              faqRight.map((item) => (
                <div class="faq-item">
                  <button class="faq-q" data-faq-toggle>
                    <span>{item.q}</span>
                    <span class="faq-arrow" aria-hidden="true">
                      ▾
                    </span>
                  </button>
                  <div class="faq-a" set:html={item.a} />
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- FİYAT LİSTESİ (opsiyonel, full width) -->
      {
        content.priceList && (
          <section class="info-card full">
            <div class="ic-head indigo-head">{content.priceList.title}</div>
            <div class="ic-body">
              <div class="table-wrap">
                <table class="price-table">
                  <tbody>
                    {content.priceList.rows.map((row) => (
                      <tr class:list={[{ camp: row.highlight }]}>
                        <td class="pt-label" set:html={row.label} />
                        <td class="pt-price">{row.price}</td>
                        <td class="pt-note">{row.note ?? "—"}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
              {content.priceList.note && (
                <p class="table-note">{content.priceList.note}</p>
              )}
            </div>
          </section>
        )
      }
    </div>

    <!-- FOOTER BANNERS -->
    <div class="d-banners">
      <div class="banner amber">
        <span class="banner-label">{t("detail.urgency")}</span>
        <span set:html={content.urgency} />
      </div>
      <div class="banner theme-banner">
        <span class="banner-label">{t("detail.pitch")}</span>
        <span set:html={content.pitch} />
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  // SSS accordion
  document.querySelectorAll("[data-faq-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      btn.closest(".faq-item")?.classList.toggle("open");
    });
  });
</script>

<style>
  .detail {
    display: flex;
    flex-direction: column;
  }

  .back-link {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-ink);
    text-decoration: none;
    margin-bottom: 1rem;
    padding: 0.4rem 0.2rem;
  }
  .back-link:hover {
    color: var(--theme-dark);
  }

  /* HERO */
  .d-hero {
    background: linear-gradient(135deg, var(--theme), var(--theme-dark));
    color: #fff;
    border-radius: var(--radius-card);
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    box-shadow: var(--shadow-card);
  }
  .d-hero-main {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }
  .d-icon {
    font-size: 2.2rem;
    width: 3.5rem;
    height: 3.5rem;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.18);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 1rem;
    flex-shrink: 0;
  }
  .d-title {
    font-size: clamp(1.4rem, 4vw, 1.9rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .d-specialty {
    display: inline-block;
    background: rgba(255, 255, 255, 0.18);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0.15rem 0.6rem;
    border-radius: 999px;
    margin-top: 0.4rem;
  }
  .d-doctor {
    font-size: var(--text-xs);
    opacity: 0.85;
    margin-top: 0.4rem;
  }
  .d-accred {
    background: #fff;
    color: var(--theme-dark);
    font-weight: 800;
    font-size: var(--text-sm);
    letter-spacing: 0.02em;
    padding: 0.45rem 0.8rem;
    border-radius: 0.6rem;
    flex-shrink: 0;
  }

  .fallback-note {
    margin-top: 1rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #b45309;
    font-size: var(--text-sm);
    padding: 0.6rem 0.9rem;
    border-radius: 0.6rem;
  }

  /* TARİH PİLLERİ */
  .date-pills {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    margin: var(--space-5) 0;
  }
  .date-pill {
    background: #fff;
    border: 1px solid var(--theme-border);
    border-top: 3px solid var(--theme-border);
    border-radius: 0.75rem;
    padding: 0.6rem 0.5rem;
    text-align: center;
    box-shadow: var(--shadow-soft);
  }
  /* Kapora pili — kritik tarih, görsel olarak ayrışır */
  .date-pill.key {
    background: var(--theme-soft);
    border-color: var(--theme);
    border-top-color: var(--theme);
  }
  .date-pill.key .dp-value {
    font-weight: 900;
  }
  .dp-label {
    display: block;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--theme-dark);
    font-weight: 700;
    margin-bottom: 0.2rem;
  }
  .dp-value {
    display: block;
    font-size: 0.92rem;
    font-weight: 800;
    color: var(--color-brand-navy);
    line-height: 1.15;
  }

  /* GRID */
  .d-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }
  .full {
    grid-column: 1 / -1;
  }

  /* INFO CARD */
  .info-card {
    background: #fff;
    border: 1px solid rgba(45, 75, 107, 0.08);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  /* Başlık barları: nötr kurumsal zemin + sol semantik aksan şeridi */
  .ic-head {
    padding: 0.75rem var(--space-5);
    font-size: var(--text-xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-brand-navy);
    background: #f1f5f9;
    border-bottom: 1px solid #e2e8f0;
    border-left: 3px solid var(--theme);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }
  .theme-head {
    border-left-color: var(--theme);
  }
  .green-head {
    border-left-color: #15803d;
  }
  .amber-head {
    border-left-color: #b45309;
  }
  .indigo-head {
    border-left-color: #4338ca;
  }
  .wa-head {
    border-left-color: #128c4b;
  }
  .ic-body {
    padding: 1rem var(--space-5);
    flex: 1;
  }

  /* Fiyat hero — güçlü değer ankoru */
  .price-hero {
    text-align: center;
    padding: var(--space-5);
    background: var(--theme-soft);
    border-bottom: 1px solid var(--theme-border);
  }
  .price-label {
    display: block;
    font-size: var(--text-2xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--theme-dark);
    font-weight: 800;
    margin-bottom: 0.3rem;
  }
  .price-big {
    font-size: clamp(2rem, 6vw, 2.6rem);
    font-weight: 900;
    color: var(--theme-dark);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }
  .price-note {
    font-size: 0.74rem;
    color: var(--color-brand-ink);
    opacity: 0.8;
    margin-top: 0.35rem;
  }

  /* Check list */
  .check-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .check-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .ic-yes {
    color: #15803d;
    font-weight: 800;
    flex-shrink: 0;
  }

  /* Dahil değil */
  .not-included {
    margin-top: 0.85rem;
    padding-top: 0.7rem;
    border-top: 1px solid #e5e7eb;
  }
  .ni-label {
    display: block;
    font-size: var(--text-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #94a3b8;
    margin-bottom: 0.45rem;
  }
  .ni-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .ni-item {
    font-size: 0.76rem;
    color: #475569;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 0.4rem;
    padding: 0.2rem 0.5rem;
  }
  .ni-x {
    color: #dc2626;
    font-weight: 700;
  }

  /* Kozlar */
  .koz-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .koz {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .koz-star {
    color: #d97706;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }
  .koz strong {
    color: var(--color-brand-navy);
  }

  /* Kurallar */
  .rule-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .rule {
    display: flex;
    align-items: flex-start;
    gap: 0.55rem;
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .rule-badge {
    background: #fde68a;
    color: #b45309;
    font-size: var(--text-2xs);
    font-weight: 800;
    border-radius: 0.3rem;
    padding: 0.1rem 0.4rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
    min-width: 1.5rem;
    text-align: center;
  }

  /* WhatsApp */
  .copy-btn {
    background: var(--theme);
    border: none;
    color: #fff;
    font-size: var(--text-2xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.4rem 0.75rem;
    min-height: 2rem;
    border-radius: 0.4rem;
    cursor: pointer;
    transition: background 0.15s;
  }
  .copy-btn:hover {
    background: var(--theme-dark);
  }
  .copy-btn.copied {
    background: #128c4b;
    color: #fff;
  }
  .wa-hint {
    font-size: 0.72rem;
    color: #94a3b8;
    font-style: italic;
    margin-bottom: 0.5rem;
  }
  .wa-text {
    background: #e7fce8;
    border-left: 3px solid #128c4b;
    border-radius: 0 0.5rem 0.5rem 0;
    padding: 0.8rem 0.9rem;
    font-size: var(--text-sm);
    line-height: 1.55;
    color: #374151;
  }
  .wa-notes {
    list-style: none;
    margin-top: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .wa-notes li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8rem;
    line-height: 1.5;
  }
  .wa-icon {
    flex-shrink: 0;
    font-weight: 800;
  }
  .wa-yes {
    color: #15803d;
  }
  .wa-warn {
    color: #b45309;
  }
  .wa-no {
    color: #dc2626;
  }

  /* SSS */
  .faq-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .faq-col {
    padding: 0 0.5rem;
  }
  .faq-col:first-child {
    border-right: 1px solid #e5e7eb;
  }
  .faq-item {
    border-bottom: 1px solid #e5e7eb;
  }
  .faq-item:last-child {
    border-bottom: none;
  }
  .faq-q {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.7rem 0.6rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-brand-navy);
    line-height: 1.4;
    font-family: inherit;
  }
  .faq-arrow {
    flex-shrink: 0;
    font-size: 0.75rem;
    color: #94a3b8;
    transition: transform 0.2s;
  }
  .faq-item.open .faq-arrow {
    transform: rotate(180deg);
  }
  .faq-a {
    display: none;
    padding: 0 0.6rem 0.8rem;
    font-size: var(--text-sm);
    line-height: 1.55;
    color: var(--color-brand-ink);
  }
  .faq-item.open .faq-a {
    display: block;
  }

  /* Fiyat tablosu */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .price-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 26rem;
  }
  .price-table td {
    padding: 0.55rem 0.8rem;
    border-bottom: 1px solid #e5e7eb;
    font-size: 0.84rem;
    vertical-align: middle;
  }
  .price-table tr:last-child td {
    border-bottom: none;
  }
  .price-table tr.camp td {
    background: var(--theme-soft);
  }
  .pt-price {
    text-align: right;
    font-weight: 800;
    color: var(--theme-dark);
    white-space: nowrap;
  }
  .pt-note {
    font-size: 0.74rem;
    color: #64748b;
  }
  .camp .pt-note {
    color: var(--theme-dark);
    font-weight: 600;
  }
  .table-note {
    font-size: var(--text-2xs);
    color: #94a3b8;
    font-style: italic;
    margin-top: 0.5rem;
  }

  /* Banner'lar */
  .d-banners {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
    margin-top: var(--space-5);
  }
  .banner {
    border-radius: var(--radius-card);
    padding: 1rem 1.2rem;
    font-size: var(--text-sm);
    line-height: 1.55;
    text-align: center;
  }
  .banner.amber {
    background: #fffbeb;
    border: 1px solid #fcd34d;
  }
  .banner.theme-banner {
    background: var(--theme-soft);
    border: 1px solid var(--theme-border);
  }
  .banner-label {
    display: block;
    font-size: var(--text-2xs);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.4rem;
  }
  .banner.amber .banner-label {
    color: #b45309;
  }
  .banner.theme-banner .banner-label {
    color: var(--theme-dark);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 720px) {
    .date-pills {
      grid-template-columns: repeat(2, 1fr);
    }
    .d-grid {
      grid-template-columns: 1fr;
    }
    .full {
      grid-column: 1;
    }
    .faq-columns {
      grid-template-columns: 1fr;
    }
    .faq-col:first-child {
      border-right: none;
    }
    .d-banners {
      grid-template-columns: 1fr;
    }
    .d-hero {
      padding: 1.25rem;
    }
  }
</style>
