---
/* Kök / — varsayılan dile (EN) anında yönlendir.
   Astro i18n redirectToDefaultLocale kapalı; bu sayfa anında JS + meta(0) ile
   yönlendirir, kullanıcı "Redirecting..." metni görmez/beklemez. */
import { defaultLang } from "@/i18n/ui";
// BASE_URL'in trailing slash'ı garantili değil; normalize et
const base = import.meta.env.BASE_URL.replace(/\/+$/, "");
const target = `${base}/${defaultLang}/`;
---

<!doctype html>
<html lang={defaultLang}>
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>IME Clinic · Sales Portal</title>
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </head>
  <body></body>
</html>
